# --- Python (illustrative placeholder only — no language has been chosen;
# --- see README.md "Technology Roadmap") ---
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
.eggs/
build/
dist/
.installed.cfg

# --- Virtual environments ---
.venv/
venv/
env/
ENV/

# --- Notebooks ---
.ipynb_checkpoints/

# --- Environment and secrets ---
.env
.env.*
!.env.example
*.key
*.pem
secrets.*

# --- Data ---
# Client and evidence data is confidential by default. Only explicitly
# whitelisted sample data (data/samples/) should ever be committed.
data/input/*
data/output/*
!data/input/.gitkeep
!data/output/.gitkeep

# --- Testing and coverage ---
.pytest_cache/
.coverage
htmlcov/
.tox/

# --- Editor and OS files ---
.vscode/
.idea/
.DS_Store
Thumbs.db

# --- Logs ---
*.log
